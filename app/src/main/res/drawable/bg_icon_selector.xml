<?xml version="1.0" encoding="utf-8"?>
<!-- Selector background cho icon: đổi màu khi được chọn -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Trạng thái được chọn: nền vàng nhạt + viền -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/nav_item_bg_selected" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/accent" />
        </shape>
    </item>
    <!-- Trạng thái mặc định: trong suốt -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_alt" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
