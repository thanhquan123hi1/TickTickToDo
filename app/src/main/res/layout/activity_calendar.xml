<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- này dùng để làm thanh tool bar -->
    <!-- thanh tool bar dùng để làm thanh tiêu đề cho app -->
    <!-- containeer bao bọc bên ngoài -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar">
        <!-- Đây chính là thanh công cụ thực tế mà người dùng nhìn thấy. Các thuộc tính bên trong dùng để tùy chỉnh giao diện của nó -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_calendar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:titleTextColor="@color/text_on_primary"
            app:navigationIconTint="@color/text_on_primary"
            app:title="@string/nav_calendar" />
    </com.google.android.material.appbar.AppBarLayout>
    <!-- sử dụng linear layout -->
    <!-- sắp xếp từ trên xuống dưới nhờ vertical-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- CalendarView -->
        <CalendarView
            android:id="@+id/calendar_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface" />
        <!-- kẻ line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Selected date label -->
        <!-- hiển thị thông tin mà người dùng nhập -->

        <TextView
            android:id="@+id/tv_selected_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@color/surface" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Task list for selected date -->
        <!-- hiên thị các task -->
        <!-- height =  0  , weight = 1 sẽ cho nó chiếm toàn bộ phânf trống -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_calendar_tasks"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/background"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

        <!-- Empty state -->

        <TextView
            android:id="@+id/tv_calendar_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/msg_no_tasks_on_date"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:visibility="gone" />


    </LinearLayout>


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_task_calendar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/btn_add_task"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/primary"
        app:tint="@color/text_on_primary" />


</androidx.coordinatorlayout.widget.CoordinatorLayout>
