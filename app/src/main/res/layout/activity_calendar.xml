<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_calendar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:navigationIconTint="@color/text_on_primary"
            app:title="@string/nav_calendar"
            app:titleTextColor="@color/text_on_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="0dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_calendar_surface_card"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_prev_month"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_rail_btn_ripple"
                    android:contentDescription="@string/calendar_previous_month"
                    android:padding="8dp"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_month_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_next_month"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_rail_btn_ripple"
                    android:contentDescription="@string/calendar_next_month"
                    android:padding="8dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView style="@style/CalendarWeekdayStyle" android:text="@string/calendar_weekday_mon" />
                <TextView style="@style/CalendarWeekdayStyle" android:text="@string/calendar_weekday_tue" />
                <TextView style="@style/CalendarWeekdayStyle" android:text="@string/calendar_weekday_wed" />
                <TextView style="@style/CalendarWeekdayStyle" android:text="@string/calendar_weekday_thu" />
                <TextView style="@style/CalendarWeekdayStyle" android:text="@string/calendar_weekday_fri" />
                <TextView style="@style/CalendarWeekdayStyle" android:text="@string/calendar_weekday_sat" />
                <TextView style="@style/CalendarWeekdayStyle" android:text="@string/calendar_weekday_sun" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_calendar_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_selected_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_calendar_surface_card"
            android:paddingTop="6dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_calendar_tasks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="84dp" />

            <TextView
                android:id="@+id/tv_calendar_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/msg_no_tasks_on_date"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_task_calendar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/btn_add_task"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/primary"
        app:tint="@color/text_on_primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
