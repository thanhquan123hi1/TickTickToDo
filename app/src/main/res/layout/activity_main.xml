<?xml version="1.0" encoding="utf-8"?>
<!--
: Đây là một loại Layout dạng "xếp chồng". Khác với LinearLayout (xếp nối tiếp nhau), mọi thứ bạn đặt vào bên trong FrameLayout mặc định sẽ đè lên nhau (giống như các lớp của một cái bánh hamburger) và nằm ở góc trên cùng bên trái. -->

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="68dp"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_main_content_flat"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="0dp"
            android:stateListAnimator="@null">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/task_surface_caption"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_task_surface_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/nav_next_7_days"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fab_add_task"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/btn_add_task"
                    android:src="@drawable/ic_add"
                    android:stateListAnimator="@null"
                    app:borderWidth="0dp"
                    app:elevation="0dp"
                    app:backgroundTint="@color/primary"
                    app:fabCustomSize="52dp"
                    app:pressedTranslationZ="0dp"
                    app:tint="@color/text_on_primary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/add_task_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_soft_surface"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="52dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/btn_add_task"
                    android:src="@drawable/ic_add"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/btn_add_task"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_scan"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/primary_dark"
                    android:contentDescription="Scan Task"
                     />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_tasks"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:clipToPadding="false"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="20dp" />

                <TextView
                    android:id="@+id/tv_empty"
                    android:layout_width="240dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="@string/msg_no_tasks"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/overlay_dim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="68dp"
        android:background="#4D1F1B16"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/nav_rail"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:background="@color/surface"
        android:elevation="10dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <FrameLayout
            android:id="@+id/btn_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="28dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_avatar_circle"
                android:contentDescription="@string/nav_avatar"
                android:padding="11dp"
                android:src="@drawable/ic_avatar_placeholder"
                app:tint="@color/text_on_primary" />
        </FrameLayout>

        <ImageButton
            android:id="@+id/rail_btn_tasks"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_rail_btn_ripple"
            android:contentDescription="@string/nav_rail_tasks"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_task" />

        <ImageButton
            android:id="@+id/rail_btn_calendar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_rail_btn_ripple"
            android:contentDescription="@string/nav_calendar"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_calendar" />

        <ImageButton
            android:id="@+id/rail_btn_school_calendar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_rail_btn_ripple"
            android:contentDescription="@string/nav_school_calendar"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_school_calendar" />

        <ImageButton
            android:id="@+id/rail_btn_diary"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_rail_btn_ripple"
            android:contentDescription="@string/diary_title"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/rail_btn_filter"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_rail_btn_ripple"
            android:contentDescription="@string/nav_filters"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_filter" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/rail_btn_tools"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_rail_btn_ripple"
            android:contentDescription="@string/nav_tools"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_tools" />

        <ImageButton
            android:id="@+id/rail_btn_completed"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_rail_btn_ripple"
            android:contentDescription="@string/filter_completed"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_completed" />

        <ImageButton
            android:id="@+id/rail_btn_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_rail_btn_ripple"
            android:contentDescription="@string/nav_settings"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_settings" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/expanded_panel"
        android:layout_width="296dp"
        android:layout_height="match_parent"
        android:layout_marginStart="60dp"
        android:background="@drawable/bg_panel_rounded"
        android:elevation="10dp"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="24dp"
        android:paddingEnd="12dp"
        android:paddingBottom="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_panel_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:background="@color/divider" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/panel_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

</FrameLayout>
