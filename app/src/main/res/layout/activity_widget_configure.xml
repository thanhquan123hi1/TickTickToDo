<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_settings_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/widget_mode_title"
            android:textStyle="bold" />

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radio_widget_mode_tasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_mode_tasks" />

            <RadioButton
                android:id="@+id/radio_widget_mode_timer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_mode_timer" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/section_widget_tasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_task_count" />

            <Spinner
                android:id="@+id/spinner_widget_task_limit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <CheckBox
                android:id="@+id/checkbox_widget_include_completed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/widget_include_completed" />

            <CheckBox
                android:id="@+id/checkbox_widget_show_deadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_show_deadline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/widget_theme" />

            <Spinner
                android:id="@+id/spinner_widget_theme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/section_widget_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_timer_duration" />

            <Spinner
                android:id="@+id/spinner_timer_preset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/et_timer_custom_minutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/widget_timer_custom_hint"
                android:inputType="number"
                android:maxLength="3"
                android:visibility="gone" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_widget_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/widget_save" />
    </LinearLayout>
</ScrollView>

