<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog cho phép người dùng tạo category mới với tên và icon tùy chọn -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="8dp">

    <!-- Tiêu đề nhập tên danh mục -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/category_name_hint"
        app:boxBackgroundColor="@color/surface_alt">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_category_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Label chọn icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="10dp"
        android:text="@string/category_icon_label"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Grid icon để người dùng chọn -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_icons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />
</LinearLayout>
