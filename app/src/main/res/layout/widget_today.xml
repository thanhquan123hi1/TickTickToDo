<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/widget_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_today"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_widget_badge"
            android:includeFontPadding="false"
            android:minHeight="22dp"
            android:minWidth="38dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingTop="3dp"
            android:paddingEnd="10dp"
            android:paddingBottom="3dp"
            android:textColor="#FF7F7F7F"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="" />

        <ImageButton
            android:id="@+id/widget_btn_add"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_widget_add_button"
            android:contentDescription="@string/widget_today_add"
            android:padding="12dp"
            android:src="@drawable/ic_add" />
    </LinearLayout>

    <ListView
        android:id="@+id/widget_task_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:scrollbars="none" />

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:text="@string/widget_today_empty"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingTop="6dp"
        android:text="@string/app_name"
        android:textColor="#FF8E8E8E"
        android:textSize="12sp" />
</LinearLayout>
