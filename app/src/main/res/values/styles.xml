<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="WidgetCalendarDayLabel">
        <item name="android:layout_width">16dp</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/widget_calendar_muted</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="WidgetCalendarDate">
        <item name="android:layout_width">16dp</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/widget_calendar_text</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="WidgetCalendarDateMuted" parent="WidgetCalendarDate">
        <item name="android:textColor">@color/widget_calendar_muted</item>
    </style>

    <style name="CalendarWeekdayStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DiaryEmojiStyle">
        <item name="android:layout_width">36dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_diary_emoji_chip</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">16sp</item>
    </style>


</resources>

