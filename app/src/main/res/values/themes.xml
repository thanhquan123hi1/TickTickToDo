<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TickTick" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/background</item>
    </style>
    <!-- Base.Theme.TickTickLà theme gốc của app, kế thừa Theme.Material3.DayNight.NoActionBar.Nó đặt các màu chính như colorPrimary, colorAccent, và android:windowBackground.
* Theme.TickTickLà theme chính dùng công khai trong app, kế thừa từ theme gốc để dễ mở rộng sau này.
* NavItemShapeĐịnh kiểu cho item trong NavigationView:- bo góc item qua itemShapeAppearance- màu nền/icon/text theo trạng thái bằng các selector- khoảng đệm trên/dưới/trái/phải bằng các itemShapeInset...
* NavItemShapeAppearanceĐịnh nghĩa hình dạng bo góc cho nav item, với góc rounded và kích thước 12dp.
* Theme.TickTick.SplashTheme cho splash screen (Android12+):- màu nền splash- icon ở giữa- theme sẽ áp dụng sau khi splash kết thúc (postSplashScreenTheme)
 -->
    <style name="Theme.TickTick" parent="Base.Theme.TickTick" />

    <!-- NavigationView item shape with rounded corners -->
    <style name="NavItemShape" parent="Widget.Material3.NavigationView">
        <item name="itemShapeAppearance">@style/NavItemShapeAppearance</item>
        <item name="itemShapeFillColor">@color/nav_item_selector</item>
        <item name="itemIconTint">@color/nav_item_icon_selector</item>
        <item name="itemTextColor">@color/nav_item_text_selector</item>
        <item name="itemShapeInsetStart">8dp</item>
        <item name="itemShapeInsetEnd">8dp</item>
        <item name="itemShapeInsetTop">4dp</item>
        <item name="itemShapeInsetBottom">4dp</item>
    </style>

    <style name="NavItemShapeAppearance" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    //splash screen
    <style name="Theme.TickTick.Splash" parent="Theme.SplashScreen">

        <!-- màu nền -->
        <item name="windowSplashScreenBackground">@color/primary</item>

        <!-- icon ở giữa -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>

        <!-- theme sau khi splash kết thúc -->
        <item name="postSplashScreenTheme">@style/Theme.TickTick</item>

    </style>
</resources>